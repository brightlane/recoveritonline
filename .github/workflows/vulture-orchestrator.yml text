name: Vulture Factory Orchestrator
on:
  schedule:
    - cron: '0 4 * * *'  # Daily 4AM EDT (post-midnight generation)
  workflow_dispatch:
    inputs:
      pages_to_generate:
        description: 'Pages to generate (default: 50)'
        required: false
        default: '50'
        type: number
  push:
    paths:
      - 'vulture-*.js'
      - 'generator-core.js'
      - 'pages/**'
      - '.github/workflows/vulture-orchestrator.yml'

env:
  NODE_VERSION: '20'
  PAGES_BASE: 'pages'
  SITE_BASEURL: ${{ github.event.repository.html_url }}/pages

concurrency:
  group: vulture-factory-${{ github.ref }}
  cancel-in-progress: true

jobs:
  setup:
    runs-on: ubuntu-latest
    outputs:
      pages_to_gen: ${{ steps.calc.outputs.pages }}
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: ${{ env.NODE_VERSION }}
          cache: 'npm'
          
      - name: Install dependencies
        run: npm ci --only=production
        
      - id: calc
        name: Calculate pages
        run: |
          PAGES=${{ inputs.pages_to_generate || 50 }}
          echo "pages=$PAGES" >> $GITHUB_OUTPUT
          echo "Generating $PAGES vulture pages daily..."

  generate-content:
    needs: setup
    runs-on: ubuntu-latest
    strategy:
      matrix:
        batch: [1, 2, 3, 4, 5]  # Parallel batches for speed
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: ${{ env.NODE_VERSION }}
          
      - name: Install deps
        run: npm ci
        
      - name: Generate vulture batch ${{ matrix.batch }}
        env:
          BATCH_START: ${{ (matrix.batch - 1) * 10 + 1 }}
          BATCH_END: ${{ matrix.batch * 10 }}
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          node vulture-generator.js $BATCH_START $BATCH_END
          
      - name: Quality check
        run: node quality-check.js

  seo-optimization:
    needs: generate-content
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: ${{ env.NODE_VERSION }}
          
      - name: Inject SEO meta
        run: node seo-meta-injector.js
        
      - name: Generate sitemap
        run: node generate-sitemap.js
        
      - name: Update index
        run: node generate-index.js

  deploy:
    needs: seo-optimization
    runs-on: ubuntu-latest
    permissions:
      contents: write
      pages: write
      id-token: write
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup Pages
        uses: actions/configure-pages@v5
        
      - name: Upload artifact
        uses: actions/upload-pages-artifact@v3
        with:
          path: './pages'
          
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4

  notify:
    needs: deploy
    if: always()
    runs-on: ubuntu-latest
    steps:
      - name: Notify success
        if: success()
        uses: actions/github-script@v7
        with:
          script: |
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: '✅ **Vulture Factory**: Deployed ${{ needs.setup.outputs.pages_to_gen }} fresh pages! Live at ${{ github.event.repository.html_url }}/pages'
            })
